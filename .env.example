# =============================================================================
# Centralized environment variables for the Movies monorepo
# =============================================================================
# Copy this file to .env (root of the repo) and fill in your values.
# .env is gitignored — never commit real credentials.
#
# Docker Compose reads this file for ALL services.
# When running a bot locally, run from the repo root so python-dotenv finds it.
# =============================================================================


# ---------------------------------------------------------------------------
# PostgreSQL (shared by all bots)
# ---------------------------------------------------------------------------
# Use a strong random string — e.g.: openssl rand -hex 32
POSTGRES_PASSWORD=change_me


# ---------------------------------------------------------------------------
# Gmail SMTP (shared by all bots)
# ---------------------------------------------------------------------------
GMAIL_USER=you@gmail.com

# 16-character App Password (NOT your real Gmail password).
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled.)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Address to RECEIVE notifications (can be the same as GMAIL_USER)
NOTIFY_EMAIL=you@gmail.com


# ---------------------------------------------------------------------------
# AMC IMAX bot
# ---------------------------------------------------------------------------
AMC_API_KEY=your-amc-api-key-here

# Theatre to monitor (leave blank to use lookup mode on first run)
AMC_THEATRE_NUMBER=

# Polling intervals (minutes)
AMC_POLL_INTERVAL_MINUTES=15
AMC_PEAK_POLL_INTERVAL_MINUTES=5

# Peak window in local time (HH:MM) — when ticket drops typically occur
AMC_PEAK_HOURS_START=09:00
AMC_PEAK_HOURS_END=12:00


# ---------------------------------------------------------------------------
# Nitehawk Cinema scraper
# ---------------------------------------------------------------------------

# Off-peak polling interval (minutes)
NITEHAWK_POLL_INTERVAL_MINUTES=30

# Peak polling interval (minutes)
NITEHAWK_PEAK_POLL_INTERVAL_MINUTES=15

# Peak window in local time (HH:MM).
# Default is 11am–6pm. Run `python analyze.py` after a few weeks to tune.
NITEHAWK_PEAK_HOURS_START=11:00
NITEHAWK_PEAK_HOURS_END=18:00
