# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Gmail address used to SEND notifications
GMAIL_USER=you@gmail.com

# 16-character App Password (NOT your real Gmail password).
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled.)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Address to RECEIVE notifications (can be the same as GMAIL_USER)
NOTIFY_EMAIL=you@gmail.com

# Off-peak polling interval in minutes (default: 30)
# POLL_INTERVAL_MINUTES=30

# Peak polling interval in minutes (default: 15)
# PEAK_POLL_INTERVAL_MINUTES=15

# Peak window in local time HH:MM — poll more frequently during this range.
# Default is 11am–6pm, a reasonable starting guess.
# After a few weeks, run `python analyze.py` to see the actual distribution
# and tune these values to match when Nitehawk really posts new programming.
# PEAK_HOURS_START=11:00
# PEAK_HOURS_END=18:00

# Path to the SQLite database file (default: ./nitehawk.db)
# Override this in GitHub Actions / Docker to point to the right location.
# DB_FILE=NitehawkScraper/nitehawk.db
